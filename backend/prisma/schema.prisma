
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model Question {
  id              String   @id @default(uuid())

  question        String
  referenceAnswer String?

  category        String
  difficulty      String

  tags            String[]

  createdAt       DateTime @default(now())
}